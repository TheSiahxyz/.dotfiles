#!/bin/sh

progs="$HOME/Private/git/THESIAH/public/progs.csv"
aurhelper="yay"

if [ ! -f "$progs" ]; then
    echo "Default file $progs not found."
    echo "Please enter the path to your CSV file:"
    read -r progs

    case "$progs" in
    ~/*) progs="$HOME${progs#~/}" ;;
    esac

    if [ ! -f "$progs" ]; then
        echo "File $progs not found. Exiting."
        exit 1
    fi
fi

while IFS=',' read -r helper package comment; do
    case "$helper" in
    \#*) continue ;;
    esac
    if [ -z "$helper" ]; then
        sudo pacman --noconfirm --needed -S "$package"
    elif [ "$helper" = "A" ]; then
        sudo -u "$USER" $aurhelper -S --noconfirm "$package" >/dev/null 2>&1
    elif [ "$helper" = "P" ]; then
        yes | pip install "$package" >/dev/null 2>&1 || yes | pipx install "$package" >/dev/null 2>&1
    fi
done <"$progs"
