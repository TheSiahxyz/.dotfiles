#!/bin/sh

# Displays today's precipication chance (☔), daily high (🎐), and daily low (🥶) and high (🌞).
# Usually intended for the statusbar.

LOCATION=$(curl -s http://ip-api.com/json | jq -r '[.regionName, .countryCode] | join(",")')

url="${WTTRURL:-wttr.in}"
weatherreport="${XDG_CACHE_HOME:-${HOME}/.cache}/weatherreport"
weatherreportjson="${XDG_CACHE_HOME:-${HOME}/.cache}/weatherreport.json"

# Get a weather report from 'wttr.in' and save it locally.
saveweath() { timeout --signal=1 2s curl -sf "$url/$LOCATION" >"$weatherreport" || exit 1; }
getforecast() { timeout --signal=1 2s curl -sf "$url/$LOCATION?format=j1" >"$weatherreportjson" || exit 1; }

# Forecast should be updated every 3 hours.
checkforecast() { [ -s "$weatherreportjson" ] && [ "$(find "$weatherreportjson" -mmin -179 2>/dev/null)" ]; }

# Get the current hour to determine which hourly block to use
get_current_hour() {
    date +%H
}

# Extract data from the hourly forecast closest to the current time
get_nearest_hourly() {
    current_hour=$(get_current_hour)

    # Calculate the nearest hourly index (each index represents a 3-hour window)
    hour_index=$((current_hour / 3))

    # Extract the correct hourly forecast using jq
    jq ".weather[0].hourly[$hour_index]" "$weatherreportjson"
}

# Extract precipitation chance for the nearest hourly forecast
getprecipchance() {
    get_nearest_hourly | jq -r '.chanceofrain'
}

# Extract wind speed for the nearest hourly forecast
getwind() {
    get_nearest_hourly | jq -r '.windspeedKmph'
}

# Extract temperature for the nearest hourly forecast
gettemp() {
    get_nearest_hourly | jq -r '.tempC'
}

# Extract the feels-like temperature for the nearest hourly forecast
getfeelslike() {
    get_nearest_hourly | jq -r '.FeelsLikeC'
}

getdesc() {
    get_nearest_hourly | jq -r '.weatherDesc[0].value'
}

showweather() {
    getforecast
    printf "%s: ☔%s 🎐%sm/s 🌞%s°(%s°)\n" "$(getdesc)" "$(getprecipchance)" "$(getwind)" "$(gettemp)" "$(getfeelslike)"
}

case $BLOCK_BUTTON in
1)
    [ "$MANPAGER" = "less -s" ] && pager=true || pager=false
    [ "$pager" = "false" ] && {
        export MANPAGER='less -s'
        export LESS="R"
        export LESS_TERMCAP_mb="$(printf '%b' '[1;31m')"
        export LESS_TERMCAP_md="$(printf '%b' '[1;36m')"
        export LESS_TERMCAP_me="$(printf '%b' '[0m')"
        export LESS_TERMCAP_so="$(printf '%b' '[01;44;33m')"
        export LESS_TERMCAP_se="$(printf '%b' '[0m')"
        export LESS_TERMCAP_us="$(printf '%b' '[1;32m')"
        export LESS_TERMCAP_ue="$(printf '%b' '[0m')"
        export LESSOPEN="| /usr/bin/highlight -O ansi %s 2>/dev/null"
    }
    setsid -f "$TERMINAL" -e less -Sf "$weatherreport"
    [ "$pager" = "false" ] && {
        export MANPAGER="sh -c 'col -bx | bat -l man -p'"
        export MANROFFOPT="-c"
    }
    ;;
2) getforecast && showweather ;;
3) notify-send "🌈 Weather module" "\- Left click for full forecast
- Middle click to update forecast
☔: Chance of rain/snow
🥶: Daily low
🌞: Daily high" ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

checkforecast || { saveweath && getforecast; }

showweather
