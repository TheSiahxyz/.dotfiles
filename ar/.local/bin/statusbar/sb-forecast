#!/bin/sh

# Displays today's snow chance (ًںڈ‚), precipication chance (âک”), humidity (ًں’§), wind speed (ًںژگ), and current (feel like) temperature (ًںŒ‍).
# Usually intended for the statusbar.

LOCATION=$(curl -s http://ip-api.com/json | jq -r '[.regionName, .countryCode] | join(",")')

url="${WTTRURL:-wttr.in}"
weatherreport="${XDG_CACHE_HOME:-${HOME}/.cache}/weatherreport"
weatherreportjson="${XDG_CACHE_HOME:-${HOME}/.cache}/weatherreport.json"

error() {
    notify-send "â›” Failed to update $1"
    exit 1
}

# Get a weather report from 'wttr.in' and save it locally.
getweatherreport() {
    (timeout --signal=1 5s curl -sf "$url/$LOCATION" >"$weatherreport" &&
        printf "\nUpdated: %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" >>"$weatherreport") ||
        error "report"
}

getweatherreportjson() {
    curl -sf "$url/$LOCATION?format=j1" >"$weatherreportjson" || error "reportjson"
}

# Forecast should be updated every 3 hours, but set 3600 to check for reliability.
checkforecast() {
    [ -s "$1" ] && [ "$(($(date +%s) - $(stat -c %Y "$1")))" -le 3600 ]
}

get_current_hour() { date +%H | sed 's/^0*//'; }

get_nearest_hourly() {
    current_hour=$(get_current_hour)
    hour_index=$((current_hour / 3))
    jq ".weather[0].hourly[$hour_index]" "$weatherreportjson"
}

getprecip() { get_nearest_hourly | jq -r '.chanceofrain'; }

gethighprecip() { jq -r '.weather[0].hourly[].chanceofrain' "$weatherreportjson" | sort -rn | head -1; }

getsnow() { get_nearest_hourly | jq -r '.chanceofsnow'; }

getwind() { get_nearest_hourly | jq -r '.windspeedKmph'; }

gettemp() { get_nearest_hourly | jq -r '.tempC'; }

getfeelslike() { get_nearest_hourly | jq -r '.FeelsLikeC'; }

getlowtemp() { jq -r '.weather[0].hourly[].tempC' "$weatherreportjson" | sort -n | head -1; }

gethightemp() { jq -r '.weather[0].hourly[].tempC' "$weatherreportjson" | sort -rn | head -1; }

gethumidity() {
    humidity=$(get_nearest_hourly | jq -r '.humidity')
    case "$humidity" in
    [0-9] | [1-2][0-9]) echo "ًںڈœï¸ڈ: $humidity%" ;;
    [3-4][0-9]) echo "ًںŒ²: $humidity%" ;;
    [5-6][0-9]) echo "ًں’§: $humidity%" ;;
    [7-8][0-9]) echo "ًں’¦: $humidity%" ;;
    9[0-9] | 100) echo "ًںŒٹ: $humidity%" ;;
    esac
}

getdesc() { get_nearest_hourly | jq -r '.weatherDesc[0].value' | sed 's/ $//'; }

showweather() { [ "$(getsnow)" -eq 0 ] && printf "âک”%s%% ًںŒ‍%sآ°\n" "$(getprecip)" "$(gettemp)" || printf "ًںڈ‚%s%% âک”%s%% ًںŒ‍%sآ°\n" "$(getsnow)" "$(getcurrentprecip)" "$(gettemp)"; }

todayweather() {
    printf "ًںŒˆ Today's weather: %s\nًںڈ‚: %s%%\nâک”: %s(%s)%%\n%s\nًںژگ: %sm/s\nًںŒ‍: %sآ°(%sآ°)\nًں¥¶: %sآ°\nًں¥µ: %sآ°\n" \
        "$(getdesc)" "$(getsnow)" "$(getprecip)" "$(gethighprecip)" "$(gethumidity)" "$(getwind)" "$(gettemp)" "$(getfeelslike)" "$(getlowtemp)" "$(gethightemp)"
}

case $BLOCK_BUTTON in
1)
    [ "$MANPAGER" = "less -s" ] && pager=true || pager=false
    [ "$pager" = "false" ] && {
        export MANPAGER='less -s'
        export LESS="R"
        export LESS_TERMCAP_mb="$(printf '%b' '[1;31m')"
        export LESS_TERMCAP_md="$(printf '%b' '[1;36m')"
        export LESS_TERMCAP_me="$(printf '%b' '[0m')"
        export LESS_TERMCAP_so="$(printf '%b' '[01;44;33m')"
        export LESS_TERMCAP_se="$(printf '%b' '[0m')"
        export LESS_TERMCAP_us="$(printf '%b' '[1;32m')"
        export LESS_TERMCAP_ue="$(printf '%b' '[0m')"
        export LESSOPEN="| /usr/bin/highlight -O ansi %s 2>/dev/null"
    }
    setsid -f "$TERMINAL" -e less -Sf "${XDG_CACHE_HOME:-${HOME}/.cache}/weatherreport"
    [ "$pager" = "false" ] && {
        export MANPAGER="sh -c 'col -bx | bat -l man -p'"
        export MANROFFOPT="-c"
    }
    ;;
2) getweatherreport && getweatherreportjson && showweather ;;
3)
    notify-send "ًںŒˆ Weather module (updates every 3 hours)" "\- Left click for full forecast
- Middle click to update forecast
ًںڈ‚: Chance of snow (hidden if it's 0)
âک”: Chance of rain
ًں’§: Humidity (icon changes depending on the level)
ًںژگ: Wind speed
ًںŒ‍: Current (feel like) temperature
ًں¥¶: Daily lowest temperature
ًں¥µ: Daily highest temperature"
    notify-send "$(todayweather)"
    ;;
6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

checkforecast "$weatherreport" || getweatherreport
checkforecast "$weatherreportjson" || getweatherreportjson
showweather
pkill -RTMIN+5 "${STATUSBAR:-dwmblocks}"
