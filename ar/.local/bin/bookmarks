#!/bin/sh

checkopen() {
    # Browser check
    if type xdg-open >/dev/null 2>&1; then
        open=xdg-open
    elif type open >/dev/null 2>&1; then
        open=open # for macOS
    elif type links >/dev/null 2>&1; then
        open=links
    elif type lynx >/dev/null 2>&1; then
        open=lynx
    else
        echo "No browser found" >&2
        exit 1
    fi
}

bm() {
    profile_dir=$(find ~/.mozilla/firefox -type d -name "*.default*" | head -n 1)
    bookmarks_path="$profile_dir/places.sqlite"
    tmp_bookmark_dir="${XDG_CACHE_HOME:-$HOME/.cache}/firefox_tmp"
    tmp_bookmark_file="$tmp_bookmark_dir/bookmark.sqlite"

    mkdir -p "$tmp_bookmark_dir"
    cp -f "$bookmarks_path" "$tmp_bookmark_file"

    checkopen

    # Check for dmenu or fallback to fzf
    if type dmenu >/dev/null 2>&1; then
        selection_tool='dmenu -i -l 20 -p "Choose a bookmark to open:"'
    else
        selection_tool="fzf --cycle --ansi --delimiter='|' --with-nth=1..-2"
    fi

    sqlite_query="
    SELECT b.title || ' | ' || p.url AS bookmark
    FROM moz_bookmarks b
    JOIN moz_places p ON b.fk = p.id
    WHERE b.type = 1 AND p.url LIKE 'http%' AND b.title NOT NULL
    ORDER BY b.dateAdded DESC;
    "

    choice=$(sqlite3 "$tmp_bookmark_file" "$sqlite_query" |
        eval "$selection_tool" |
        cut -d'|' -f2 | xargs) # xargs trims any extra whitespace

    if [ -n "$choice" ]; then
        "$open" "$choice"
    fi
}

his() {
    cols=$(expr "$COLUMNS" / 3)
    sep='{|}'
    profile_dir=$(find ~/.mozilla/firefox -type d -name "*.default*" | head -n 1)
    history_path="$profile_dir/places.sqlite"
    tmp_history_dir="${XDG_CACHE_HOME:-$HOME/.cache}/tmp/history"
    tmp_history_file="$tmp_history_dir/history.sqlite"

    mkdir -p "$tmp_history_dir"
    cp -f "$history_path" "$tmp_history_file"

    checkopen

    # Determine whether to use dmenu or fzf
    if type dmenu >/dev/null 2>&1; then
        selection_tool='dmenu -i -l 20 -p "Choose a history to open:"'
    else
        selection_tool="fzf --cycle --ansi --multi"
    fi

    sqlite3 -separator "$sep" "$tmp_history_file" \
        "SELECT substr(p.title, 1, $cols) || '$sep' || p.url
    FROM moz_places p
    JOIN moz_historyvisits hv ON hv.place_id = p.id
    ORDER BY hv.visit_date DESC LIMIT 100" |
        awk -F "$sep" '{printf "%-'$cols's  \033[36m%s\033[0m\n", $1, $2}' |
        eval "$selection_tool" | sed 's#.*\(https*://\)#\1#' | xargs $open >/dev/null 2>/dev/null
}

geturls() {
    if [ -f ~/.local/share/thesiah/urls ]; then
        URLS=$(cat ~/.local/share/thesiah/snippets ~/.local/share/thesiah/urls)
    else
        URLS=$(cat ~/.local/share/thesiah/snippets)
    fi

    # Extract names in quotes for dmenu display
    CHOICE=$(echo "$URLS" | grep -v -e '^#' -e '^$' | awk -F'"' '{print $2}' | dmenu -i -l 50 -p "Choose a URL to open:")

    # Exit if no choice is made
    [ -z "$CHOICE" ] && exit

    # Find the matching URL for the chosen name
    URL=$(echo "$URLS" | grep -v -e '^#' -e '^$' | grep "\"$CHOICE\"" | awk '{print $1}')
}

while getopts "bchop" opt; do
    case $opt in
    b) bm ;;
    c) geturls && xdotool type "$URL" ;;
    h) his ;;
    o) geturls && "$BROWSER" --new-window "$URL" ;;
    p) geturls && "$BROWSER" --private-window "$URL" ;;
    *) ;;
    esac
done
