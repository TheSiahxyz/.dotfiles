#!/bin/sh

browsercheck() {
    pidof $BROWSER >/dev/null && echo "$BROWSER is locked. Check if $BROWSER is running." && exit
}

checkopen() {
    case "$(command -v xdg-open || command -v open || command -v links || command -v lynx)" in
    *xdg-open) open=xdg-open ;;
    *open) open=open ;;
    *links) open=links ;;
    *lynx) open=lynx ;;
    *) echo "No browser found" >&2 && exit 1 ;;
    esac
}

openinbrowser() {
    case $BROWSER in
    firefox) profile_dir=$(find ~/.mozilla/firefox -type d -name "*.default-default*" | head -n 1) ;;
    librewolf) profile_dir=$(find ~/.librewolf -type d -name "*.default-default*" | head -n 1) ;;
    *) echo "Default browser path is needed." && exit ;;
    esac
    db_path="$profile_dir/places.sqlite"
    tmp_dir="${XDG_CACHE_HOME:-$HOME/.cache}/mozilla/firefox/$USER.default-default"
    tmp_file="$tmp_dir/$1.sqlite"
    mkdir -p "$tmp_dir"
    cp -f "$db_path" "$tmp_file"
    checkopen
    type dmenu >/dev/null 2>&1 &&
        selection="dmenu -i -l 20 -p \"Choose a $1 to open:\"" ||
        selection="fzf --cycle --ansi --delimiter='|' --with-nth=1..-2"
    choice=$(sqlite3 "$tmp_file" "$sqlite_query" | eval "$selection" | cut -d'|' -f2 | sed 's|.*\(https://\)|\1|' | xargs)
    [ -n "$choice" ] && "$open" "$choice" || exit
}

browserbookmark() {
    browsercheck
    sqlite_query="
    SELECT b.title || ' | ' || p.url AS bookmark
    FROM moz_bookmarks b
    JOIN moz_places p ON b.fk = p.id
    WHERE b.type = 1 AND p.url LIKE 'http%' AND b.title NOT NULL
    ORDER BY b.dateAdded DESC;
    "
    openinbrowser "bookmark"
}

browserhistory() {
    browsercheck
    cols=$((${COLUMNS:-90} / 3))
    sqlite_query="
    SELECT substr(p.title, 1, $cols) || ' | ' || p.url
    FROM moz_places p
    JOIN moz_historyvisits hv ON hv.place_id = p.id
    ORDER BY hv.visit_date DESC LIMIT 100;
    "
    openinbrowser "history"
}

geturls() {
    [ -f ~/.local/share/thesiah/urls ] &&
        URLS=$(cat ~/.local/share/thesiah/snippets ~/.local/share/thesiah/urls) ||
        URLS=$(cat ~/.local/share/thesiah/snippets)
    CHOICE=$(echo "$URLS" | grep -v -e '^#' -e '^$' | awk -F'"' '{print $2}' | dmenu -i -l 50 -p "Choose a URL to open:")
    [ -z "$CHOICE" ] && exit
    URL=$(echo "$URLS" | grep -v -e '^#' -e '^$' | grep "\"$CHOICE\"" | awk '{print $1}')
}

while getopts "bchopt" opt; do
    case $opt in
    b) browserbookmark ;;
    c) geturls && xdotool type "$URL" ;;
    o) geturls && "$BROWSER" --new-window "$URL" ;;
    p) geturls && "$BROWSER" --private-window "$URL" ;;
    t) browserhistory ;;
    *) ;;
    esac
done
