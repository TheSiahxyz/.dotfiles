#!/bin/sh

create_new_session() {
    session_name=$1
    session_path=${2:-"$PWD"} # Default to current directory if no path is provided
    [ -z "$session_name" ] && { printf "New session name: " && read -r session_name; }
    [ -n "$TMUX" ] && (tmux new-session -d -s "$session_name" -c "$session_path" && tmux switch-client -t "$session_name") ||
        tmux new -s "$session_name" -c "$session_path"
    exit
}

while getopts "s" opt; do
    case $opt in
    s)
        sesh connect "$(
            sesh list | fzf-tmux -p 70%,60% \
                --no-sort --ansi --border-label ' sesh ' --prompt '⚡  ' \
                --header '^a all ^t tmux ^c configs ^d .dotfiles ^g git ^v private ^b public ^r scripts ^s suckless ^f zoxide ^x tmux kill ^h home' \
                --bind 'tab:down,btab:up' \
                --bind 'ctrl-a:change-prompt(⚡  )+reload(sesh list)' \
                --bind 'ctrl-t:change-prompt(🪟  )+reload(sesh list -t)' \
                --bind 'ctrl-c:change-prompt(⚙️  )+reload(sesh list -c)' \
                --bind 'ctrl-f:change-prompt(🔎  )+reload(sesh list -z)' \
                --bind 'ctrl-h:change-prompt(🏠  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ~)' \
                --bind 'ctrl-g:change-prompt(  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ~/Private/git)' \
                --bind 'ctrl-d:change-prompt(🔯  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ~/.dotfiles)' \
                --bind 'ctrl-v:change-prompt(🧑  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ~/Private)' \
                --bind 'ctrl-b:change-prompt(👯  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ~/Public)' \
                --bind 'ctrl-r:change-prompt(👟  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ~/.local/bin)' \
                --bind 'ctrl-s:change-prompt(🦴  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ~/.local/src/suckless)' \
                --bind 'ctrl-x:execute(tmux kill-session -t {})+change-prompt(⚡  )+reload(sesh list)' \
                --bind 'ctrl-c:abort'
        )" 2>/dev/null
        exit
        ;;
    *) ;;
    esac
done || exit

[ $# -gt 0 ] && {
    [ -d "$1" ] && create_new_session "$(basename "$1")" "$1" || create_new_session "$1"
} || {
    ! tmux ls >/dev/null 2>&1 && create_new_session || {
        session=$( (
            tmux ls
            echo "[new session]"
        ) | fzf | cut -d: -f1)
        [ -z "$session" ] && exit || ([ "$session" = "[new session]" ] && create_new_session || tmux attach -t "$session")
    }
}
