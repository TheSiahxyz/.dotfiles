#!/bin/sh

create_new_session() {
    session_name=$1
    session_path=${2:-"$PWD"} # Default to current directory if no path is provided

    if [ -z "$session_name" ]; then
        printf "New session name: "
        read -r session_name
    fi

    if [ -n "$TMUX" ]; then
        tmux new-session -d -s "$session_name" -c "$session_path"
        tmux switch-client -t "$session_name"
    else
        tmux new -s "$session_name" -c "$session_path"
    fi
}

while getopts "s" opt; do
    case $opt in
    s)
        sesh connect "$(
            sesh list | fzf-tmux -p 70%,60% \
                --no-sort --ansi --border-label ' sesh ' --prompt '⚡  ' \
                --header '  ^a all ^t tmux ^c configs ^d .dotfiles ^v private ^b public ^r scripts ^s suckless ^f zoxide ^x tmux kill ^g home' \
                --bind 'tab:down,btab:up' \
                --bind 'ctrl-a:change-prompt(⚡  )+reload(sesh list)' \
                --bind 'ctrl-t:change-prompt(🪟  )+reload(sesh list -t)' \
                --bind 'ctrl-c:change-prompt(⚙️  )+reload(sesh list -c)' \
                --bind 'ctrl-f:change-prompt(🔎  )+reload(sesh list -z)' \
                --bind 'ctrl-g:change-prompt(🏠  )+reload(fd -H -d 2 -t d -E .Trash . ~)' \
                --bind 'ctrl-x:execute(tmux kill-session -t {})+change-prompt(⚡  )+reload(sesh list)' \
                --bind 'ctrl-d:change-prompt(🔯  )+reload(fd -H -d 2 -t d -E .Trash . ~/.dotfiles)' \
                --bind 'ctrl-v:change-prompt(🧑  )+reload(fd -H -d 2 -t d -E .Trash . ~/Private)' \
                --bind 'ctrl-b:change-prompt(👯  )+reload(fd -H -d 2 -t d -E .Trash . ~/Public)' \
                --bind 'ctrl-r:change-prompt(👟  )+reload(fd -H -d 2 -t d -E .Trash . ~/.local/bin)' \
                --bind 'ctrl-s:change-prompt(🦴  )+reload(fd -H -d 2 -t d -E .Trash . ~/.local/src/suckless)'
        )"
        exit 0
        ;;
    *) ;;
    esac
done

[ $# -gt 0 ] && {
    # Check if the argument is a valid path, and if so, use the directory name as the session name
    if [ -d "$1" ]; then
        create_new_session "$(basename "$1")" "$1" && exit 0
    else
        create_new_session "$1" && exit 0
    fi
}

! tmux ls >/dev/null 2>&1 && create_new_session && exit 0

session=$( (
    tmux ls
    echo "[new session]"
) | fzf | cut -d: -f1)
[ -z "$session" ] && exit 0
[ "$session" = "[new session]" ] && create_new_session || tmux attach -t "$session"
