#!/bin/sh

create_new_session() {
    session_name=$1
    session_path=${2:-"$PWD"} # Default to current directory if no path is provided
    [ -z "$session_name" ] && { printf "New session name: " && read -r session_name; }
    if tmux has-session -t "$session_name" 2>/dev/null; then
        tmux switch-client -t "$session_name"
    else
        if [ -n "$TMUX" ]; then
            tmux new-session -d -s "$session_name" -c "$session_path"
            tmux switch-client -t "$session_name"
        else
            tmux new -s "$session_name" -c "$session_path"
        fi
    fi
}

open_staged_files() {
    # If files are provided as arguments, use them; otherwise, use fzf to select files
    if [ "$#" -gt 0 ]; then
        resolved_files="$*"
    else
        # Use fzf to select files and store them in a string with newline as a separator
        IFS='
'
        files=$(git status -s | awk '{print $2}' | grep -v '^$' | fzf-tmux --preview "bat --color=always {}" --reverse --multi --select-1 --exit-0)

        # Check if any files were selected, and exit if not
        [ -z "$files" ] && return 0

        # Resolve each file to its absolute path
        resolved_files=""
        for file in $files; do
            resolved_files="$resolved_files $(realpath "$(git rev-parse --show-toplevel)/$file")"
        done
    fi

    # Remove leading/trailing whitespace and split resolved_files into positional parameters
    set -- "$(echo "$resolved_files" | xargs -n1 echo)"

    eval "${EDITOR:-nvim} $@"
}

sessionizer() {
    path="$(
        sesh list | fzf-tmux -p 85%,70% \
            --no-sort --cycle --ignore-case --ansi --border=sharp --multi --border-label "╢ TheSiahxyz ╟" --prompt "⚡  " \
            --header "^a all ^t tmux ^e sesh ^f zoxide ^h home ^c configs ^d .dotfiles ^g git ^u staged files ^k desktop ^v private ^b public ^r scripts ^s suckless ^x tmux kill M-CR open ^/ help" \
            --bind "ctrl-a:change-prompt(⚡  )+reload(sesh list)" \
            --bind "ctrl-b:change-prompt(👯  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ${XDG_PUBLICSHARE_DIR:-${HOME}/Public} | sed 's|$HOME|~|g')" \
            --bind "ctrl-c:change-prompt(🗂️  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ${XDG_CONFIG_DIR:-${HOME}/.config} | sed 's|$HOME|~|g')" \
            --bind "ctrl-d:change-prompt(⚙️  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ${XDG_DOTFILES_DIR:-${HOME}/.dotfiles} | sed 's|$HOME|~|g')" \
            --bind "ctrl-e:change-prompt(📑  )+reload(sesh list -c)" \
            --bind "ctrl-f:change-prompt(🔎  )+reload(sesh list -z)" \
            --bind "ctrl-g:change-prompt(  )+reload(fd -H -d 2 -t d -E .Trash -E .git . $HOME/Private/repos | sed 's|$HOME|~|g')" \
            --bind "ctrl-h:change-prompt(🏠  )+reload(fd -H -d 2 -t d -E .Trash -E .git . $HOME | sed 's|$HOME|~|g')" \
            --bind "ctrl-k:change-prompt(🖥️  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ${XDG_DESKTOP_DIR:-${HOME}/Desktop} | sed 's|$HOME|~|g')" \
            --bind "ctrl-r:change-prompt(👟  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ${XDG_SCRIPTS_HOME:-${HOME}/.local/bin} | sed 's|$HOME|~|g')" \
            --bind "ctrl-s:change-prompt(🦴  )+reload(fd -H -d 2 -t d -E .Trash -E .git . ${XDG_SOURCES_HOME:-${HOME}/.local/src}/suckless | sed 's|$HOME|~|g')" \
            --bind "ctrl-t:change-prompt(🪟  )+reload(sesh list -t)" \
            --bind "ctrl-u:change-prompt(📝  )+reload(git -C $(git rev-parse --show-toplevel) status -s | awk -v pwd=\"$PWD\" '{print pwd \"\/\" \$2}' | grep -v '^$' | sed 's|$HOME|~|g')" \
            --bind "ctrl-v:change-prompt(🧑  )+reload(fd -H -d 2 -t d -E .Trash -E .git . $HOME/Private | sed 's|$HOME|~|g')" \
            --bind "ctrl-x:execute(tmux kill-session -t {})+change-prompt(⚡  )+reload(sesh list)" \
            --bind "alt-enter:execute(nvim {})+abort" \
            --bind 'ctrl-/:change-prompt(❓  )+reload(echo "^a all
^b public
^c configs
^d .dotfiles
^e sesh config
^f zoxide
^g git
^h home
^k desktop
^r scripts
^s suckless
^t tmux
^u staged files
^v private
^x tmux kill
M-CR open in nvim
^/ help")'
    )" 2>/dev/null

    case "$path" in
    ^*) sessionizer ;;
    *)
        sesh connect "$path" >/dev/null 2>&1 || open_staged_files "$path"
        exit
        ;;
    esac
}

while getopts "s" opt; do
    case $opt in
    s)
        sessionizer
        ;;
    *) ;;
    esac
done

if [ $# -gt 0 ]; then
    if [ -d "$1" ]; then
        create_new_session "$(basename "$1")" "$1"
    else
        create_new_session "$1"
    fi
else
    if ! tmux ls >/dev/null 2>&1; then
        create_new_session
    else
        session=$(tmux ls echo "[new session]" | fzf | cut -d: -f1)
        [ -z "$session" ] && exit
        if [ "$session" = "[new session]" ]; then
            create_new_session
        else
            tmux attach -t "$session"
        fi
    fi
fi
