#!/bin/sh

open_staged_files() {
    if [ "$#" -gt 0 ]; then
        resolved_files="$*"
    else
        IFS='
        '
        files=$(git status -s | awk '{print $2}' | grep -v '^$' | fzf-tmux --preview "bat --color=always {}" --reverse --multi --select-1 --exit-0)

        [ -z "$files" ] && return 0

        resolved_files=""
        for file in $files; do
            resolved_file=$(realpath "$(git rev-parse --show-toplevel)/$file")
            resolved_files="$resolved_files $resolved_file"
        done
    fi

    nvim_commands=""
    for file in $resolved_files; do
        expanded_file=$(eval echo "$file")
        first_changed_line=$(git diff --unified=0 --no-prefix -- "$expanded_file" | grep "^@@ " | sed -E 's/^@@ -[0-9]+(,[0-9]+)? \+([0-9]+)(,[0-9]+)? @@.*/\2/' | head -n 1)

        [ -z "$first_changed_line" ] && continue

        nvim_commands="$nvim_commands +$first_changed_line $expanded_file"
    done

    eval "${EDITOR:-nvim} $nvim_commands"
}

sessionizer() {
    path="$(
        sesh list | fzf-tmux -p 85%,70% \
            --no-sort --cycle --ignore-case --ansi --border=sharp --multi --border-label "â•˘ TheSiahxyz â•ź" --prompt "âšˇ  " \
            --header "^a all ^t tmux ^e sesh ^f zoxide ^h home ^c configs ^d .dotfiles ^g git ^u staged files ^k desktop ^v private ^b public ^r scripts ^s suckless ^x tmux kill M-CR open ^/ help" \
            --reverse \
            --bind "ctrl-a:change-prompt(âšˇ  )+reload(sesh list)" \
            --bind "ctrl-b:change-prompt(đź‘Ż  )+reload(fd -H -d 1 -t d -E .Trash -E .git -E repos . ${XDG_PUBLICSHARE_DIR:-${HOME}/Public} | sed 's|$HOME|~|g')" \
            --bind "ctrl-c:change-prompt(đź—‚ď¸Ź  )+reload(fd -H -d 2 -t d -E .Trash -E .git -E .cache . ${XDG_CONFIG_DIR:-${HOME}/.config} | sed 's|$HOME|~|g')" \
            --bind "ctrl-d:change-prompt(âš™ď¸Ź  )+reload(fd -H -d 1 -t d -E .Trash -E .git -E .cache . ${XDG_DOTFILES_DIR:-${HOME}/.dotfiles} | sed 's|$HOME|~|g')" \
            --bind "ctrl-e:change-prompt(đź“‘  )+reload(sesh list -c)" \
            --bind "ctrl-f:change-prompt(đź”Ž  )+reload(sesh list -z)" \
            --bind "ctrl-g:change-prompt(ď‚›  )+reload(fd -H -d 1 -t d -E .Trash -E .git -E .cache . $HOME/Private/repos $HOME/Public/repos | sed 's|$HOME|~|g')" \
            --bind "ctrl-h:change-prompt(đźŹ   )+reload(fd -d 4 -t d -E .cache . $HOME | sed 's|$HOME|~|g')" \
            --bind "ctrl-k:change-prompt(đź–Ąď¸Ź  )+reload(fd -H -d 2 -t d -E .Trash -E .git -E .cache . ${XDG_DESKTOP_DIR:-${HOME}/Desktop} | sed 's|$HOME|~|g')" \
            --bind "ctrl-r:change-prompt(đź‘ź  )+reload(fd -H -d 2 -t d -E .Trash -E .git -E zsh -E .cache . ${XDG_SCRIPTS_HOME:-${HOME}/.local/bin} | sed 's|$HOME|~|g')" \
            --bind "ctrl-s:change-prompt(đź¦´  )+reload(find ${XDG_SOURCES_HOME:-${HOME}/.local/src}/suckless -maxdepth 2 -type d -name .git -prune -o -type d -print | sed 's|$HOME|~|g')" \
            --bind "ctrl-t:change-prompt(đźŞź  )+reload(sesh list -t)" \
            --bind "ctrl-u:change-prompt(đź“ť  )+reload(git -C $(git rev-parse --show-toplevel) status -s | awk -v pwd=\"$PWD\" '{print pwd \"\/\" \$2}' | grep -v '^$' | sed 's|$HOME|~|g')" \
            --bind "ctrl-v:change-prompt(đź§‘  )+reload(fd -H -d 1 -t d -E .Trash -E .git -E repos . $HOME/Private | sed 's|$HOME|~|g')" \
            --bind "ctrl-x:execute(tmux kill-session -t {})+change-prompt(âšˇ  )+reload(sesh list)" \
            --bind "alt-enter:execute(nvim {})+abort" \
            --bind 'ctrl-/:change-prompt(âť“  )+reload(echo "^a all
^b public
^c configs
^d .dotfiles
^e sesh config
^f zoxide
^g git
^h home
^k desktop
^r scripts
^s suckless
^t tmux
^u staged files
^v private
^x tmux kill
M-CR open in nvim
^/ help")'
    )" 2>/dev/null

    case "$path" in
    ^*) sessionizer ;;
    *)
        sesh connect "$path" >/dev/null 2>&1 || open_staged_files "$path"
        exit
        ;;
    esac
}

sessionizer
