#!/bin/sh

# Define variables
SERVER="192.168.0.5"

getmount() {
    [ -z "$1" ] && mp="$(find "/media/$USER" /mnt -mindepth 1 -maxdepth 1 -type d 2>/dev/null | dmenu -i -p "Mount this drive where?")" || mp="$1"
    test -n "$mp"
    if [ ! -d "$mp" ]; then
        mkdiryn=$(printf "No\\nYes" | dmenu -i -p "$mp does not exist. Create it?")
        [ "$mkdiryn" = "Yes" ] && (mkdir -p "$mp" 2>/dev/null || sudo -A mkdir -p "$mp")
    fi
}

# Set SUDO_ASKPASS to use the dmenupass script
export SUDO_ASKPASS="$HOME/.local/bin/dmenupass"

# Prompt for password using dmenupass
PASSWORD=$(dmenu -fn Monospace-18 -P -p "Enter Samba Password:" <&-)
[ -z "$PASSWORD" ] && exit 1

# Get list of shares
SHARES=$(
    smbclient -L "$SERVER" -U% -A /dev/stdin <<EOF 2>/dev/null | awk '/Disk/ {print $1}'
username=$(whoami)
password=$PASSWORD
EOF
)
[ -z "$SHARES" ] && notify-send "⛔ No samba shares available." && exit 1

# Select share using dmenu
SHARE=$(echo "$SHARES" | dmenu -i -p "Select a share to mount:")
[ -z "$SHARE" ] && exit 1

# Mount the selected share using sudo with SUDO_ASKPASS
getmount "/media/$USER/$SHARE" && echo "$PASSWORD" | sudo -A mount -t cifs -o username="$(whoami)",password="$PASSWORD" "//$SERVER/$SHARE" "$mp"

# Notify the user
[ $? -eq 0 ] && notify-send "📡 Successfully mounted" "//$SERVER/$SHARE to $mp/$SHARE" || notify-send "❌ Failed samba mount" "//$SERVER/$SHARE"
