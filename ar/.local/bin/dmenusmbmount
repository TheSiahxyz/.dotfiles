#!/bin/sh

# Define variables
SERVER="127.0.0.1"
MOUNT_POINT="/media/samba"

# Set SUDO_ASKPASS to use the dmenupass script
export SUDO_ASKPASS="$HOME/.local/bin/dmenupass"

# Prompt for password using dmenupass
PASSWORD=$(dmenu -fn Monospace-18 -P -p "Enter Samba Password:" <&-)
[ -z "$PASSWORD" ] && { echo "No password entered. Exiting." ; exit 1 ; }

# Get list of shares
SHARES=$(smbclient -L "$SERVER" -U% -A /dev/stdin <<EOF 2>/dev/null | awk '/Disk/ {print $1}'
username=$(whoami)
password=$PASSWORD
EOF
)
[ -z "$SHARES" ] && { echo "No shares available. Exiting." ; exit 1 ; }

# Select share using dmenu
SHARE=$(echo "$SHARES" | dmenu -i -p "Select a share to mount:")
[ -z "$SHARE" ] && { echo "No share selected. Exiting." ; exit 1 ; }

# Create mount point if it doesn't exist
[ -d "$mp" ] || mkdir -p "$MOUNT_POINT"

# Mount the selected share using sudo with SUDO_ASKPASS
echo "$PASSWORD" | sudo -A mount -t cifs -o username=$(whoami),password="$PASSWORD" //$SERVER/$SHARE "$MOUNT_POINT"

# Notify the user
[ $? -eq 0 ] && notify-send "Samba Mount" "Successfully mounted //$SERVER/$SHARE to $MOUNT_POINT" || notify-send "Samba Mount" "Failed to mount //$SERVER/$SHARE"
